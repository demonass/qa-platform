# 使用已编译的二进制文件，跳过构建阶段
FROM golang:1.22-alpine

# 安装 ca-certificates 和 curl
RUN apk --no-cache add ca-certificates curl

WORKDIR /app

# 直接复制已编译的二进制文件
COPY backend/main .

# 暴露端口
EXPOSE 8081

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8081/health || exit 1

# 启动命令
CMD ["./main"]